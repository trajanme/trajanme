---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="omiya | daywizz">
  <section class="flex flex-col items-center justify-center min-h-[60vh] px-4 text-center">
    <!-- アイコンプレースホルダー -->
    <div class="w-20 h-20 rounded-2xl bg-omiya/20 flex items-center justify-center">
      <i class="ri-gift-line text-3xl text-omiya"></i>
    </div>

    <h1 class="mt-6 text-3xl font-bold text-gray-900">omiya</h1>
    <p class="mt-2 text-gray-500">日本のおみやげ文化を世界へ</p>

    <div class="mt-8 px-6 py-3 rounded-full bg-gray-100 text-gray-500 text-sm font-medium">
      Coming Soon
    </div>

    <a
      href="/"
      class="mt-8 inline-flex items-center gap-1 text-sm font-medium text-primary hover:opacity-80 transition-opacity"
    >
      <i class="ri-arrow-left-line"></i>
      daywizz トップへ戻る
    </a>
  </section>
</BaseLayout>
