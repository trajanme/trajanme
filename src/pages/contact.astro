---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="お問い合わせ - daywizz" description="daywizz へのお問い合わせ">
  <section class="py-16">
    <div class="max-w-2xl mx-auto px-4">
      <h1 class="text-2xl font-bold text-gray-900 text-center">お問い合わせ</h1>
      <p class="mt-2 text-center text-gray-500">
        ご質問・ご要望・お仕事のご相談など、お気軽にどうぞ。
      </p>

      <!-- フォーム -->
      <form
        action="mailto:shintaro@daywizz.com"
        method="post"
        enctype="text/plain"
        class="mt-10 space-y-6"
      >
        <!-- 名前 -->
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
            お名前 <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
            placeholder="山田 太郎"
          />
        </div>

        <!-- メール -->
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            メールアドレス <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
            placeholder="example@mail.com"
          />
        </div>

        <!-- 内容 -->
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
            お問い合わせ内容 <span class="text-red-500">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-y"
            placeholder="お問い合わせ内容をご記入ください"
          ></textarea>
        </div>

        <!-- プライバシー同意 -->
        <div class="flex items-start gap-2">
          <input
            type="checkbox"
            id="privacy"
            name="privacy"
            required
            class="mt-1 w-4 h-4 text-primary border-gray-300 rounded focus:ring-primary/30"
          />
          <label for="privacy" class="text-sm text-gray-600">
            <a href="/apps/picolle/privacy/" class="text-primary underline hover:opacity-80">プライバシーポリシー</a>に同意します
          </label>
        </div>

        <!-- 送信 -->
        <div class="text-center">
          <button
            type="submit"
            class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-white font-medium rounded-full hover:opacity-90 transition-opacity shadow-sm"
          >
            送信する
            <i class="ri-send-plane-line"></i>
          </button>
        </div>
      </form>

      <!-- X での連絡 -->
      <div class="mt-12 rounded-xl border border-gray-100 bg-gray-50 p-6 text-center">
        <p class="text-sm text-gray-600 mb-3">
          X（旧 Twitter）でもお気軽にご連絡ください
        </p>
        <a
          href="https://x.com/shin_daywizz"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:opacity-80 transition-opacity"
        >
          <i class="ri-twitter-x-line text-lg"></i>
          @shin_daywizz
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
