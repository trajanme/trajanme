---
import type { Platform } from '../data/apps';

interface Props {
  name: string;
  tagline: string;
  color: string;
  href: string;
  platforms: Platform[];
  icon: string;
  version?: string;
}

const { name, tagline, color, href, platforms, icon, version } = Astro.props;

const platformIcons: Record<Platform, { icon: string; label: string }> = {
  iOS: { icon: 'ri-apple-line', label: 'iOS' },
  Android: { icon: 'ri-android-line', label: 'Android' },
  Web: { icon: 'ri-global-line', label: 'Web' },
};
---

<a
  href={href}
  class="group block rounded-2xl border border-gray-100 bg-white p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200"
>
  <div class="flex items-start gap-4">
    <!-- アプリアイコン -->
    {icon ? (
      <img src={icon} alt={name} class="w-14 h-14 rounded-xl shrink-0" />
    ) : (
      <div
        class="w-14 h-14 rounded-xl shrink-0"
        style={`background-color: var(--color-${color});`}
      />
    )}

    <div class="min-w-0">
      <h3 class="text-lg font-bold text-gray-900 group-hover:text-primary transition-colors">
        {name}
      </h3>
      <p class="mt-1 text-sm text-gray-500">{tagline}</p>

      <!-- プラットフォームバッジ + バージョン -->
      {(platforms.length > 0 || version) && (
        <div class="mt-2 flex flex-wrap gap-1.5">
          {platforms.map((p) => (
            <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-500">
              <i class={platformIcons[p].icon}></i>
              {platformIcons[p].label}
            </span>
          ))}
          {version && (
            <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-500">
              {version}
            </span>
          )}
        </div>
      )}
    </div>
  </div>

  <div class="mt-4 flex items-center text-sm font-medium text-primary opacity-0 group-hover:opacity-100 transition-opacity">
    詳しく見る
    <i class="ri-arrow-right-line ml-1"></i>
  </div>
</a>
