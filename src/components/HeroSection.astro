---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { title, subtitle, ctaText, ctaHref } = Astro.props;
---

<section class="relative py-24 md:py-32 overflow-hidden">
  <!-- グラデーション背景 -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-secondary/5 to-white -z-10" />

  <div class="max-w-3xl mx-auto px-4 text-center">
    <h1 class="text-3xl md:text-5xl font-bold text-gray-900 leading-tight">
      {title}
    </h1>

    {subtitle && (
      <p class="mt-4 text-lg md:text-xl text-gray-500">
        {subtitle}
      </p>
    )}

    {ctaText && ctaHref && (
      <div class="mt-8">
        <a
          href={ctaHref}
          class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-medium rounded-full hover:opacity-90 transition-opacity shadow-sm"
        >
          {ctaText}
          <i class="ri-arrow-right-line"></i>
        </a>
      </div>
    )}
  </div>
</section>
